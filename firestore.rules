rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isCreator() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuth() && doc.exists && doc.data.get('role', 'user') == 'creator';
    }

    // ════ Profils utilisateurs ════
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /conversations/{convId} {
        allow read, write: if isOwner(userId);

        match /messages/{msgId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }

      match /alarms/{alarmId} {
        allow read, write: if isOwner(userId);
      }

      match /reminders/{reminderId} {
        allow read, write: if isOwner(userId);
      }

      match /events/{eventId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ════ Rapports / Signalements ════
    // Tout utilisateur connecté peut créer ET lire les rapports.
    // Le contrôle du rôle admin est géré côté client (isAdminRole).
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read, update, delete: if isAuth();
    }

    // ════ Clés développeur ════
    match /dev_keys_valid/{keyId} {
      allow read: if isAuth();
      allow create, update, delete: if isCreator();
    }

  }
}
