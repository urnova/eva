// ════════════════════════════════════════════════════
// BLOC À AJOUTER dans tes règles Firestore existantes
// (avant le dernier } fermant de ton fichier de règles)
// Ne remplace PAS tes règles existantes — ajoute juste ce bloc.
// ════════════════════════════════════════════════════

// Rapports — tout le monde peut créer, seuls creator/developer peuvent lire/modifier/supprimer
match /reports/{reportId} {
  allow create: if request.auth != null;
  allow read, update, delete: if request.auth != null &&
    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['creator', 'developer'];
}
